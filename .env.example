# Copy to .env and adjust for your environment.

# ── Execution backend ────────────────────────────────────────────────────────
# mt5linux = Python RPyC bridge (default, needs Wine + mt5linux server)
# ea       = MQL5 TradeIdeaExecutor EA over TCP (fast I/O path)
EXECUTION_BACKEND=mt5linux

# mt5linux (when EXECUTION_BACKEND=mt5linux)
MT5_HOST=localhost
MT5_PORT=18812
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

# EA TCP server (when EXECUTION_BACKEND=ea) — Python listens, EA connects in
EA_SERVER_HOST=0.0.0.0
EA_SERVER_PORT=19520

# ── API ─────────────────────────────────────────────────────────────────────
API_PORT=8001

# ── Risk / worker tuning ────────────────────────────────────────────────────
DAILY_DD_PCT=0.03
MAX_ACCOUNT_RISK_PCT=6.0
WORKER_LOOP_FAST_SEC=0.01
WORKER_LOOP_IDLE_SEC=0.1

# ── Database (lives in project root; Docker bind-mounts trade_ideas.db) ─────
# DATABASE_URL=sqlite:///trade_ideas.db

# ── AI (optional) ───────────────────────────────────────────────────────────
# One key:
# CEREBRAS_API_KEY=
# Multiple keys (comma-separated) — rotates on rate limits for higher throughput:
# CEREBRAS_API_KEYS=key-one,key-two
