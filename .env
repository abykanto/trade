# ── Paths & storage (relative to project root, or absolute) ─────────────────
RUNTIME_DIR=tmp
# LOGS_DIR=tmp/logs
# RUN_DIR=tmp/run
# PRICE_LOG_DIR=tmp/data/price_logs
DATABASE_PATH=trade_ideas.db
DATABASE_URL=sqlite:///trade_ideas.db

# ── Execution backend ───────────────────────────────────────────────────────
# mt5linux = Python RPyC bridge (default, needs Wine + mt5linux server)
# ea       = MQL5 TradeIdeaExecutor EA over TCP (fast I/O path)
EXECUTION_BACKEND=mt5linux

# mt5linux (when EXECUTION_BACKEND=mt5linux)
MT5_HOST=localhost
MT5_PORT=18812
MT5_LOGIN=108504700
MT5_PASSWORD='*6KcEuSq'
MT5_SERVER=MetaQuotes-Demo

# EA TCP server (when EXECUTION_BACKEND=ea) — Python listens, EA connects in
EA_SERVER_HOST=0.0.0.0
EA_SERVER_PORT=19520

# ── API ─────────────────────────────────────────────────────────────────────
API_PORT=8001

# ── Risk / worker tuning ────────────────────────────────────────────────────
DAILY_DD_PCT=0.03
MAX_ACCOUNT_RISK_PCT=6.0
WORKER_LOOP_FAST_SEC=0.01
WORKER_LOOP_IDLE_SEC=0.1
ENABLE_PRIME_SESSION=false
MAX_LOT_SIZE=0.02

# ── Price logging ─────────────────────────────────────────────────────────
PRICE_LOG_INTERVAL_SEC=1.0
PRICE_LOG_FLUSH_ROWS=30

