# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Local database (runtime state)
*.sqlite
*.sqlite3
*.db
*.db-shm
*.db-wal

# Logs and process/runtime dirs
*.log
logs/
run/
*.pid

# Runtime market data (tick parquet, etc.)
data/
*.parquet

# Local env overrides (.env and .env.example are tracked for reference)
.env.local
.env.*.local

# MQL5 / MetaTrader build artifacts
*.ex5
*.ex4

# IDEs and editors
.idea/
.vscode/
*.swp
*~

# Testing / coverage
.pytest_cache/
htmlcov/
.coverage
.mypy_cache/
.ruff_cache/
.tox/
.nox/

# Build / packaging
dist/
build/
*.egg-info/
*.egg

# Docker local overrides (not docker-compose.yml)
docker-compose.override.yml
docker-compose.*.local.yml

# OS
.DS_Store
Thumbs.db

# Scratch / editor leftovers
Untitled*.py
Untitled-*
