# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Runtime artifacts (logs, PIDs, parquet ticks, scratch files)
tmp/

# SQLite WAL sidecars (trade_ideas.db is tracked in project root)
*.db-shm
*.db-wal

# Local env overrides (.env is tracked in project root)
.env.local
.env.*.local

# MQL5 / MetaTrader build artifacts
*.ex5
*.ex4

# IDEs and editors
.idea/
.vscode/
*.swp
*~

# Testing / coverage
.pytest_cache/
htmlcov/
.coverage
.mypy_cache/
.ruff_cache/
.tox/
.nox/

# Build / packaging
dist/
build/
*.egg-info/
*.egg

# Docker local overrides (not docker-compose.yml)
docker-compose.override.yml
docker-compose.*.local.yml

# OS
.DS_Store
Thumbs.db
